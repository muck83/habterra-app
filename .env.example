# Copy this file to .env and fill in your Supabase project credentials.
# Get these from: https://supabase.com/dashboard → your project → Settings → API

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: set to "true" to run against in-memory mock fixtures instead
# of Supabase (useful for UI dev without credentials). Must NOT be set
# in production — main.jsx throws at startup if PROD && VITE_MOCK_MODE.
# VITE_MOCK_MODE=true
